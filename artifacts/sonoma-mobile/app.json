{
  "expo": {
    "name": "Sonoma",
    "slug": "sonoma-mobile",
    "version": "1.3.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "sonoma-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6B2D3E"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.sonomachefapp.sonoma"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
